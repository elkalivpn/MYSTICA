// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// Mystica - Multi-provider Database Schema
// ============================================
// Supported providers: SQLite (default), Supabase, Firebase
// The schema is designed to work with all providers

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("user") // user, premium, admin
  settings  String?  // JSON string for user preferences
  banned    Boolean  @default(false)
  bannedAt  DateTime?
  bannedReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  meditationSessions MeditationSession[]
  tarotReadings      TarotReading[]
  progress           UserProgress?
  reminders          Reminder[]
  subscription       Subscription?
  supportTickets     SupportTicket[]
  bugReports         BugReport[]
  activities         UserActivity[]

  @@index([email])
  @@index([role])
  @@index([banned])
}

model MeditationSession {
  id          String   @id @default(cuid())
  userId      String
  meditationId String  // Reference to meditation content
  duration    Int      // Duration in seconds
  completed   Boolean  @default(false)
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([meditationId])
}

model TarotReading {
  id            String   @id @default(cuid())
  userId        String
  cards         String   // JSON string with array of card IDs
  interpretation String? // AI-generated interpretation
  spreadType    String   @default("single") // single, three-card, celtic-cross
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model UserProgress {
  id           String   @id @default(cuid())
  userId       String   @unique
  xp           Int      @default(0)
  level        Int      @default(1)
  achievements String   @default("[]") // JSON array of achievement IDs
  streak       Int      @default(0)
  lastActive   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([level])
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  time      String   // Format: "HH:MM"
  days      String   @default("[0,1,2,3,4,5,6]") // JSON array: 0=Sunday, 6=Saturday
  enabled   Boolean  @default(true)
  message   String?
  type      String   @default("meditation") // meditation, affirmation, ritual
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([enabled])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  plan      String   @default("free") // free, premium, pro
  startDate DateTime @default(now())
  endDate   DateTime?
  status    String   @default("active") // active, expired, cancelled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stripe fields
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?
  stripeCancelAtPeriodEnd Boolean @default(false)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([plan])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

// Legacy model - kept for backwards compatibility
model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Admin Panel Models
// ============================================

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  message     String
  status      String   @default("open") // open, in_progress, resolved, closed
  priority    String   @default("normal") // low, normal, high, urgent
  category    String   @default("general") // general, technical, billing, feature_request
  assignedTo  String?  // Admin user ID
  responses   String   @default("[]") // JSON array of responses
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?
  closedAt    DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model BugReport {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  status      String   @default("new") // new, confirmed, in_progress, resolved, wont_fix
  priority    String   @default("medium") // critical, high, medium, low
  category    String   @default("other") // ui, functionality, performance, security, other
  device      String?  // Device type
  os          String?  // Operating system
  browser     String?  // Browser info
  version     String?  // App version
  assignedTo  String?  // Developer user ID
  comments    String   @default("[]") // JSON array of internal comments
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdAt])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  rollout     Int      @default(100) // Percentage of users (0-100)
  conditions  String?  // JSON string with conditions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([enabled])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   // info, warning, error, critical
  message   String
  details   String?  // JSON string with additional details
  source    String?  // Component or service that generated the log
  userId    String?  // User associated with the log (if any)
  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  action    String   // login, logout, read_tarot, meditate, etc.
  details   String?  // JSON string with action details
  metadata  String?  // JSON string with additional metadata
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AppConfiguration {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  isPublic    Boolean  @default(false) // Whether to expose in frontend
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model MeditationContent {
  id          String   @id @default(cuid())
  name        String
  description String
  duration    Int      // in minutes
  category    String
  level       String   @default("principiante") // principiante, intermedio, avanzado
  guide       String   // Guided text
  benefits    String   @default("[]") // JSON array
  steps       String   @default("[]") // JSON array
  affirmations String  @default("[]") // JSON array
  premium     Boolean  @default(false)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([active])
}

model TarotCardContent {
  id            String   @id @default(cuid())
  cardId        Int      @unique // 0-21 for Major Arcana
  name          String
  nameEs        String
  keywordsUpright String @default("[]") // JSON array
  keywordsReversed String @default("[]") // JSON array
  meaningUpright String
  meaningReversed String
  description   String
  element       String?
  planet        String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([cardId])
  @@index([active])
}
